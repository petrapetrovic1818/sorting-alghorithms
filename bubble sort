MAIN (U WEB-INF)

<%@taglib prefix="c" uri="jakarta.tags.core"%>
<%-- 
    Document   : main
    Created on : Jun 4, 2026, 5:44:38 PM
    Author     : milicakovacevic
--%>

<%@page contentType="text/html" pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
    <head>
        <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
        <title>JSP Page</title>
    </head>
    <body>
        <h1>Pocetna strana nakon prijave na sistem!</h1>
        
       <jsp:include page="/WEB-INF/pages/fragment/meni.jsp" flush="true"/>
        

        <div>
            Dobrodosla, ${loginkorisnik.ime} !

        </div>

        <div>
            <h2>Prikaz tvojih zadataka</h2>
                Broj tvojih zadataka: ${brojZadataka}

            <table border="2">
                <thead>
                    <tr>
                        <th>Naziv</th>
                        <th>Opis</th>
                        <th>Datum</th>
                        <th>Status</th>
                        <th>Dodatne akcije</th>
                    </tr>
                </thead>
                <tbody>
                    <c:forEach var="z" items="${loginkorisnik.zadaci}">

                        <tr>
                            <td>${z.naziv}</td>
                            <td>${z.opis}</td>
                            <td>${z.datum}</td>
                            <td>${z.status}</td>
                            <td>
                                <a href="/web-demo-pripr/zadaci/izmeni/${z.id}">Izmeni</a>
                                <a href="/web-demo-pripr/zadaci/obrisi/${z.id}">Obrisi</a>
                            </td>
                        </tr>
                    </c:forEach>
                </tbody>
            </table>

        </div>



        <div>

            <h2>Dodaj novi zadatak</h2>

            <form action="/web-demo-pripr/zadaci/dodaj" method="POST">

                <label for="id">Id:</label>
                <input type="text" name="id" value="" />
                
                <label for="naziv">Naziv:</label>
                <input type="text" name="naziv" value="" />

                <label for="opis">Opis:</label>
                <input type="text" name="opis" value="" />
                
                <label for="status">Status:</label>
                <input type="text" name="status" value="" />

                <input type="submit" value="Dodaj zadatak" />

            </form>

        </div>

    </body>
</html>


MENI (U WEB-INF/PAGES/FRAGMENT)

<%@taglib prefix="c" uri="jakarta.tags.core"%>
<%-- 
    Document   : meni
