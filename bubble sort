        <h1>Uloguj se!</h1>
        
        <h2>${message}</h2>
        
        <form action="/web-demo-pripr/login" method="POST">
            
            <label for="email">Email:</label>
            <input type="text" name="email" value="" />
            
            <label for="password">password:</label>
