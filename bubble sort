--%>

<div>
    
    <h4>Prikaz ulogovanih korisnika:</h4>
    
    <table border="2">
        <thead>
            <tr>
                <th>Ime</th>
                <th>Prezime</th>
                <th>Email</th>
                <th>Status</th>
                
            </tr>
        </thead>
        <tbody>
            <c:forEach var="k" items="${korisnici}">
           
            <tr>
                <td>${k.ime}</td>
                <td>${k.prezime}</td>
                <td>${k.email}</td>
                <td>${k.status}</td>
            </tr>
             </c:forEach>
        </tbody>
    </table>

    <a href="/web-demo-pripr/logout">Odjavi se</a>
    
    
</div>


IZMENI (WEB-INF/PAGES/ZADACI)

<%-- 
    Document   : zadaci
    Created on : Jun 4, 2026, 5:47:38 PM
    Author     : milicakovacevic
--%>

<%@page contentType="text/html" pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
    <head>
        <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
        <title>JSP Page</title>
    </head>
    <body>
        <h1>Izmeni odredjeni zadatak!</h1>
        
        <form action="/web-demo-pripr/zadaci/sacuvajIzmenu" method="POST">
            
                <label for="naziv">Id:</label>
                <input type="hidden" name="id" value="${zad.id}" />
                
                <label for="naziv">Naziv:</label>
                <input type="text" name="naziv" value="${zad.naziv}" />

                <label for="opis">Opis:</label>
                <input type="text" name="opis" value="${zad.opis}" />
                
                <label for="status">Status:</label>
                <input type="text" name="status" value="${zad.status}" />

                <input type="submit" value="Izmeni zadatak" />

            </form>
    </body>
</html>


