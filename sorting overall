package application.action.impl;

import application.action.ActionInterface;
import application.dto.KorisnikDto;
import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpSession;
import java.util.List;

/**
 *
 * @author PC
 */
public class LoginAction implements ActionInterface {

    @Override
    public String execute(HttpServletRequest req) {
        String korisnickoIme = req.getParameter("korisnickoIme");
        String sifra = req.getParameter("sifra");
        List<KorisnikDto> korisnici = (List<KorisnikDto>) req.getServletContext().getAttribute("korisnici");
        String page = "/login.jsp";
        for(KorisnikDto korisnik:korisnici){
            if((sifra == null || sifra.isEmpty())){
                if(korisnik.getKorisnickoIme().equals(korisnickoIme)){
                    page = "/WEB-INF/main.jsp";
                    if(korisnik.isOnline()){
                        page = "/login.jsp";
                        req.setAttribute("greska", "Greska, korisnik je vec ulogovan");
                        return page;
                    }
                    HttpSession session = req.getSession(true);
                    korisnik.setOnline(true);
                    req.setAttribute("korisnici", korisnici);
                    session.setAttribute("loginKorisnik", korisnik);
                    return page;
                }
            }
            if(korisnik.getKorisnickoIme().equals(korisnickoIme) && korisnik.getSifra().equals(sifra)){
                page = "/WEB-INF/main.jsp";
                if(korisnik.isOnline()){
                        page = "/login.jsp";
                        req.setAttribute("greska", "Greska, korisnik je vec ulogovan");
                        return page;
                    }
                HttpSession session = req.getSession(true);
                korisnik.setOnline(true);
                req.setAttribute("korisnici", korisnici);
                session.setAttribute("loginKorisnik", korisnik);
                return page;
            }
        }
        req.setAttribute("greska", "Greska, korisnik ne postoji");
        return page;
    }

    
}


