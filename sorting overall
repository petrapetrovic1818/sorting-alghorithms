package application.action.impl;

import application.action.ActionInterface;
import application.dto.KorisnikDto;
import application.dto.ZadatakDto;
import jakarta.servlet.http.HttpServletRequest;
import java.time.LocalDateTime;
import java.util.List;

/**
 *
 * @author PC
 */
public class dodajNoviAction implements ActionInterface{

    @Override
    public String execute(HttpServletRequest req) {
        KorisnikDto korisnik = (KorisnikDto) req.getSession().getAttribute("loginKorisnik");
        String naziv = req.getParameter("naziv");
        String opis = req.getParameter("opis");
        String datum = req.getParameter("datum");
        String aktivanStr = req.getParameter("aktivan");

        boolean aktivan = Boolean.parseBoolean(aktivanStr);

        ZadatakDto z = new ZadatakDto(
            naziv,
            opis,
            LocalDateTime.parse(datum),
            aktivan
        );
        korisnik.getZadaci().add(z);
        req.setAttribute("zadaci", korisnik.getZadaci());
        return "/WEB-INF/pages/korisnik/zadaci.jsp";
    }
    
}


