 */
public class SacuvajIzmenuAction implements ActionInterface {

    @Override
    public String execute(HttpServletRequest req) {
        String stariNaziv = req.getParameter("stariNaziv");
        String noviNaziv = req.getParameter("noviNaziv");
        String noviOpis = req.getParameter("noviOpis");
        KorisnikDto korisnik = (KorisnikDto) req.getSession().getAttribute("loginKorisnik");

        for (ZadatakDto z : korisnik.getZadaci()) {
            if (z.getNaziv().equals(stariNaziv)) {
                z.setNaziv(noviNaziv);
                z.setOpis(noviOpis);
                break;
            }
        }

        req.setAttribute("zadaci", korisnik.getZadaci());
        return "WEB-INF/pages/korisnik/zadaci.jsp";
    }
    
}



