import rs.ac.bg.fon.njt.web.demo.pripr.app.action.MyAction;
import rs.ac.bg.fon.njt.web.demo.pripr.app.dto.KorisnikDto;
import rs.ac.bg.fon.njt.web.demo.pripr.app.dto.ZadatakDto;

public class DodajZadatakAction extends MyAction {

    @Override
    public String execute(HttpServletRequest request) {

        HttpSession session = request.getSession();
        KorisnikDto korisnik = (KorisnikDto) session.getAttribute("loginkorisnik");

        List<ZadatakDto> zadaci = korisnik.getZadaci();

        String naziv = request.getParameter("naziv");
        String opis = request.getParameter("opis");
        String status = request.getParameter("status");
        LocalDateTime datum = LocalDateTime.now();
        int id = Integer.parseInt(request.getParameter("id"));

        zadaci.add(new ZadatakDto(id, naziv, opis, datum, status));

        return "/WEB-INF/main.jsp";
    }

}


